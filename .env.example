MONGODB_URI=
MONGODB_DB_NAME=petto
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# PEM with literal \n between lines, OR use FIREBASE_PRIVATE_KEY_BASE64 (recommended on Cloud Run)
FIREBASE_PRIVATE_KEY=
# FIREBASE_PRIVATE_KEY_BASE64=
PORT=8080
APP_ENV=development
# Public site / store listings (optional until you host pages on the domain)
CLIENT_APP_URL=https://peto.casa
DEEP_LINK_SCHEME=petto
DEEP_LINK_DOMAIN=peto.casa
# Email OTP — Resend (recommended): https://resend.com
# Use an address on your verified domain (not onboarding@resend.dev in production).
RESEND_API_KEY=
RESEND_FROM_EMAIL=peto <noreply@peto.casa>

# RevenueCat webhook (Authorization: Bearer <secret> must match RC dashboard)
REVENUECAT_WEBHOOK_SECRET=
# Optional REST API key for future admin sync
REVENUECAT_API_KEY=