MONGODB_URI=
MONGODB_DB_NAME=petto
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# PEM with literal \n between lines, OR use FIREBASE_PRIVATE_KEY_BASE64 (recommended on Cloud Run)
FIREBASE_PRIVATE_KEY=
# FIREBASE_PRIVATE_KEY_BASE64=
PORT=8080
APP_ENV=development
CLIENT_APP_URL=
DEEP_LINK_SCHEME=
DEEP_LINK_DOMAIN=
# Email OTP — option A: Resend (no SMTP server needed): https://resend.com
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Petto <onboarding@resend.dev>
# Email OTP — option B: classic SMTP (Gmail app password, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=you@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# SMTP_FROM_EMAIL=you@gmail.com
# SMTP_USE_TLS=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true